{
  "name": "vxllm",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/client": "^1.12.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:app": "turbo -F app dev",
    "dev:server": "turbo -F server dev",
    "dev:docs": "turbo -F docs dev",
    "dev:www": "turbo -F www dev",
    "db:push": "turbo -F @vxllm/db db:push",
    "db:studio": "turbo -F @vxllm/db db:studio",
    "db:generate": "turbo -F @vxllm/db db:generate",
    "db:migrate": "turbo -F @vxllm/db db:migrate",
    "db:local": "turbo -F @vxllm/db db:local",
    "dev:cli": "turbo -F cli dev"
  },
  "dependencies": {
    "@vxllm/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@vxllm/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.10"
}
